# CommuteBeh Rails API — environment variables
# Copy to .env for local dev. Never commit .env.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/commutebeh_development

# ── Auth ──────────────────────────────────────────────────────────────────────
DEVISE_JWT_SECRET_KEY=       # openssl rand -hex 64
SECRET_KEY_BASE=             # rails secret

# ── Hono microservice ─────────────────────────────────────────────────────────
# The Hono service manages transit_graph_v3.json writes.
# Rails proxies graph reads from here.
HONO_API_URL=http://localhost:3001

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,commutenavigator://

# ── Redis (Sidekiq + Rack::Attack) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Supabase Storage (Active Storage for ARWorldMap uploads) ─────────────────
SUPABASE_S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY=
SUPABASE_S3_SECRET_KEY=
SUPABASE_S3_REGION=ap-northeast-2
SUPABASE_STORAGE_BUCKET=commute-navigator-maps

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
RAILS_ENV=development
RAILS_LOG_TO_STDOUT=true
